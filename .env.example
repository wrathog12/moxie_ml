# ============================================================
#  .env.example — API Keys for the YouTube Analysis Pipeline
# ============================================================
#
# INSTRUCTIONS:
# 1. Rename this file to `.env` (remove the .example extension)
# 2. Replace the placeholder values below with your actual API keys.
# ============================================================

# AssemblyAI — speech-to-text transcription
# Get a free API key at: https://www.assemblyai.com/dashboard
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Google Gemini — LLM commentary generation
# Get a free API key at: https://aistudio.google.com/app/apikey
# The pipeline relies on the gemini-2.5-flash model via the google-genai SDK.
GOOGLE_API_KEY=your_google_api_key_here
